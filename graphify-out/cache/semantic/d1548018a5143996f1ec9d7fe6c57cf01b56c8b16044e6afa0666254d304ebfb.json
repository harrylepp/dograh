{"nodes": [{"id": "developer_workflow_schema_doc", "label": "Workflow Definition Schema", "file_type": "document", "source_file": "docs/developer/workflow-schema.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "developer_workflow_schema_workflow_definition", "label": "workflow_definition Object", "file_type": "rationale", "source_file": "docs/developer/workflow-schema.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The workflow_definition object (nodes + edges) is the same structure the dashboard visual builder reads and writes, so anything configured visually is expressible as JSON via Create from Definition / Update Agent. This keeps the UI and API as one source of truth."}, {"id": "developer_workflow_schema_node_types", "label": "Workflow Node Types", "file_type": "rationale", "source_file": "docs/developer/workflow-schema.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Node types are startCall, endCall, agentNode, globalNode, trigger, webhook, and qa. Each workflow needs exactly one startCall or trigger entry point; trigger, webhook and qa nodes are exempt from the required prompt field."}, {"id": "developer_workflow_schema_edges", "label": "Workflow Edges", "file_type": "rationale", "source_file": "docs/developer/workflow-schema.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Edges connect source/target node IDs and carry a natural-language condition the LLM evaluates to fire the transition, plus an optional transition_speech. Edge condition clarity drives routing accuracy."}, {"id": "developer_workflow_schema_extraction", "label": "agentNode Data Extraction", "file_type": "rationale", "source_file": "docs/developer/workflow-schema.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "agentNode supports extraction_enabled with extraction_variables (name/type/prompt; type in string/number/boolean) to pull structured data from the conversation into gathered_context."}], "edges": [{"source": "developer_workflow_schema_workflow_definition", "target": "developer_workflow_schema_doc", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/developer/workflow-schema.mdx", "source_location": null, "weight": 1.0}, {"source": "developer_workflow_schema_node_types", "target": "developer_workflow_schema_doc", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/developer/workflow-schema.mdx", "source_location": null, "weight": 1.0}, {"source": "developer_workflow_schema_edges", "target": "developer_workflow_schema_doc", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/developer/workflow-schema.mdx", "source_location": null, "weight": 1.0}, {"source": "developer_workflow_schema_extraction", "target": "developer_workflow_schema_doc", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/developer/workflow-schema.mdx", "source_location": null, "weight": 1.0}, {"source": "developer_workflow_schema_extraction", "target": "getting_started_send_call_data_with_webhooks_gathered_context", "relation": "shares_data_with", "confidence": "INFERRED", "confidence_score": 0.75, "source_file": "docs/developer/workflow-schema.mdx", "source_location": null, "weight": 1.0}], "hyperedges": []}