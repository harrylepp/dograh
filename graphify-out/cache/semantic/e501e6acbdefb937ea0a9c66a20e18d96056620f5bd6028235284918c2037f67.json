{"nodes": [{"id": "getting_started_add_tools_and_knowledge_base_doc", "label": "Use External Tools, Knowledge", "file_type": "document", "source_file": "docs/getting-started/add-tools-and-knowledge-base.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "getting_started_add_tools_and_knowledge_base_tool", "label": "External HTTP API Tool", "file_type": "rationale", "source_file": "docs/getting-started/add-tools-and-knowledge-base.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "A tool connects the agent to live or changing data and actions. The tool description drives when the LLM calls it. Tools must be attached to the node that needs them - creating a tool alone does not make it available."}, {"id": "getting_started_add_tools_and_knowledge_base_knowledge_base", "label": "Knowledge Base Retrieval Modes", "file_type": "rationale", "source_file": "docs/getting-started/add-tools-and-knowledge-base.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Full Document works for small files without an embeddings model; Chunked Search pulls relevant sections from large documents but requires an embeddings model configured first or processing/retrieval fails. Documents must be attached to the node, like tools."}], "edges": [{"source": "getting_started_add_tools_and_knowledge_base_tool", "target": "getting_started_add_tools_and_knowledge_base_doc", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "docs/getting-started/add-tools-and-knowledge-base.mdx", "source_location": null, "weight": 1.0}, {"source": "getting_started_add_tools_and_knowledge_base_knowledge_base", "target": "getting_started_add_tools_and_knowledge_base_doc", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "doc