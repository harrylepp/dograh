{"nodes": [{"id": "developer_webhooks_doc", "label": "Webhook Payloads", "file_type": "document", "source_file": "docs/developer/webhooks.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "developer_webhooks_webhook_payload", "label": "Webhook Payload Context Variables", "file_type": "rationale", "source_file": "docs/developer/webhooks.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Webhook nodes run asynchronously after a workflow run completes; the payload_template is rendered with run context (workflow_run_id, initial_context, gathered_context, cost_info, recording_url, transcript_url) so endpoints receive structured call results. Non-200 responses are logged but not retried unless retry_config is set."}, {"id": "developer_webhooks_authentication", "label": "Webhook Authentication Methods", "file_type": "rationale", "source_file": "docs/developer/webhooks.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Auth is configured via a stored credential supporting NONE, API_KEY (custom header), BEARER_TOKEN, BASIC_AUTH, and CUSTOM_HEADER so endpoints can require authenticated delivery without per-request secrets in the workflow."}, {"id": "developer_webhooks_webhook_node", "label": "Webhook Node", "file_type": "rationale", "source_file": "docs/developer/webhooks.mdx", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The webhook node fires HTTP requests when reached; endpoint_url, http_method, custom_headers and payload_template are configured in the workflow definition. Receivers must respond 2xx within 30s and handle duplicates idempotently."}], "edges": [{"source": "developer_webhooks_doc", "target": "developer_workflow_schema_doc", "relation": "references", "confidence": "EXTRACTED", "conf